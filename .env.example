# ============================================================
# alternance-finder — Variables d'environnement
# ============================================================
# Copier ce fichier en .env et remplir les valeurs.
# Ne jamais committer .env !
# ============================================================

# Gmail SMTP (pour envoi test uniquement en V1)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
TEST_RECIPIENT_EMAIL=aymen.ch03@gmail.com

# Limites
MAX_EMAILS_PER_DAY=20
DRY_RUN=true

# Génération (template = sans IA, openai = avec OpenAI API)
LLM_PROVIDER=template

# APIs externes (TODO — pas utilisées en V1)
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
SIRENE_API_KEY=

# LaTeX (auto = détection automatique, ou spécifier latexmk/xelatex/pdflatex)
LATEX_COMPILER=auto
